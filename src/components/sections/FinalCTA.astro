---
import ButtonCTA from "../ui/ButtonCTA.astro";
import SectionDivider from "../ui/SectionDivider.astro";
---

<section class="bg-theme-bg px-4 pb-12 pt-20">
  <SectionDivider type="wave" class="-scale-y-100 text-theme-primary" />
  <div class="mx-auto mt-8 grid max-w-6xl items-center gap-8 md:grid-cols-[1.1fr_0.9fr]">
    <div class="space-y-5">
      <h2 class="text-3xl font-light text-theme-primary md:text-5xl">¿TIENES PREGUNTAS?</h2>
      <p class="text-lg font-semibold leading-relaxed">
        ESCRÍBEME AHORA MISMO POR WHATSAPP TOCANDO EL SIGUIENTE BOTÓN
      </p>
      <ButtonCTA
        href="https://soynunawellness.com/dudas-maraton"
        target="_blank"
        rel="noopener noreferrer"
        text="RESOLVER MIS PREGUNTAS"
      />
    </div>
    <img src="/images/Mi_proyecto_4_1-4043538-1.webp" alt="" class="mx-auto w-full max-w-sm rounded-3xl object-cover shadow-sm" loading="lazy" />
  </div>
</section>

<footer class="bg-theme-primary px-4 py-5 text-center text-sm font-semibold tracking-wide text-white">
  TODOS LOS DERECHOS RESERVADOS / NUNA WELLNESS ACADEMY  / @2026
</footer>

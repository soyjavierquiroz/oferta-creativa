---
import Card from "../ui/Card.astro";
import SectionDivider from "../ui/SectionDivider.astro";

const painPoints = [
  "¿Sientes que tus postres saludables no tienen la textura ni el sabor de los tradicionales y eso te frustra?",
  "¿Te da miedo ofrecerlos porque crees que no impactarán en el cliente como quisieras?",
  "¿Estás cansada de perder dinero probando recetas que no funcionan?",
  "¿Te gustaría empezar o crecer tu emprendimiento, pero no sabes por dónde comenzar?"
];
---

<section class="relative bg-theme-surface px-4 py-20">
  <SectionDivider type="cloud" class="-scale-y-100 text-theme-bg" />
  <div class="mx-auto mt-8 max-w-6xl">
    <h2 class="text-center text-3xl font-bold leading-tight text-theme-primary md:text-5xl">
      ¿Te sientes identificada
      <br />
      <span class="text-theme-primary underline decoration-theme-accent decoration-2 underline-offset-4">con alguna…?</span>
    </h2>
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {
        painPoints.map((item) => (
          <Card class="p-6">
            <div class="flex items-start gap-4">
              <span class="mt-1 inline-flex h-6 w-6 flex-none rotate-45 rounded-sm bg-theme-accent"></span>
              <p class="text-base leading-relaxed md:text-lg">{item}</p>
            </div>
          </Card>
        ))
      }
    </div>
  </div>
</section>
